# LLM(agent 模式必需;smoke/regression 不需要)
# provider 见 @open-multi-agent/core: anthropic|openai|azure-openai|deepseek|doubao|grok|hunyuan|minimax|mimo|gemini|qiniu|bedrock|copilot
OMA_PROVIDER=anthropic
OMA_API_KEY=
# OpenAI 兼容私有/国产网关填这里(如跃阶星辰 https://api.stepfun.com/step_plan/v1);anthropic 官方留空
OMA_BASE_URL=
OMA_MODEL=claude-sonnet-4-6

# 服务
PORT=3000
DB_PATH=uitest.db

# 浏览器
BROWSER_HEADLESS=true
BROWSER_POOL_SIZE=2
# CDP 模式:连接已登录的浏览器(绕过验证码)。留空=launch 全新浏览器。
# 用法:先 chrome --remote-debugging-port=9222 手动登录后台,再设:
# BROWSER_CDP_URL=http://localhost:9222
BROWSER_CDP_URL=

# 被测目标(fixture 登录页)
TARGET_LOGIN_URL=http://localhost:3000/fixture/login.html

# 真实后台自适应登录(npm run real-login 用;填你的后台地址与凭据,本文件不入库)
TEST_LOGIN_URL=https://your-admin.example.com/
TEST_USERNAME=
TEST_PASSWORD=
