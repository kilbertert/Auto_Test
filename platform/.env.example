# ===== LLM(agent 模式必需;smoke 模式不需要)=====
# provider 见 @open-multi-agent/core: anthropic|openai|azure-openai|deepseek|doubao|grok|hunyuan|minimax|mimo|gemini|qiniu|bedrock|copilot
OMA_PROVIDER=anthropic
OMA_API_KEY=
# OpenAI 兼容私有/国产网关填这里(如 https://your-gateway/v1);anthropic 官方留空
OMA_BASE_URL=
OMA_MODEL=claude-sonnet-4-6

# ===== 服务 =====
PORT=3000
DB_PATH=uitest.db

# ===== 浏览器 =====
BROWSER_HEADLESS=true
BROWSER_POOL_SIZE=2

# ===== 被测目标 =====
# 默认本地 fixture 登录页;可改为真实后台 URL
TARGET_LOGIN_URL=http://localhost:3000/fixture/login.html
